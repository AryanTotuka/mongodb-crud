pipeline {  
  agent any  
  
  environment {  
    CI = 'true'  
  }  
  
  stages {  
    stage('Checkout') {  
      steps {  
        checkout scm  
      }  
    }  
  
    stage('Install backend dependencies') {  
      steps {  
        script {  
          if (isUnix()) {  
            sh 'npm install'  
          } else {  
            bat 'npm install'  
          }  
        }  
      }  
    }  
  
    stage('Install frontend dependencies') {  
      steps {  
        dir('my-app') {  
          script {  
            if (isUnix()) {  
              sh 'npm install'  
            } else {  
              bat 'npm install'  
            }  
          }  
        }  
      }  
    }  
  
    stage('Test frontend') {  
      steps {  
        script {  
          if (isUnix()) {  
            dir('my-app') {
              sh 'npm test -- --watchAll=false'  
            }
          } else {  
            // Jest has a bug where it ignores tests inside directories starting with a dot (like .jenkins)
            // Workaround: Move the my-app folder to a temporary directory outside the hidden folder,
            // run the tests, and then move it back.
            bat '''
              if not exist "%TEMP%\\jenkins-workspaces" mkdir "%TEMP%\\jenkins-workspaces"
              if exist "%TEMP%\\jenkins-workspaces\\%JOB_NAME%-my-app" rmdir /S /Q "%TEMP%\\jenkins-workspaces\\%JOB_NAME%-my-app"
              move my-app "%TEMP%\\jenkins-workspaces\\%JOB_NAME%-my-app"
              cd /D "%TEMP%\\jenkins-workspaces\\%JOB_NAME%-my-app"
              call npm test -- --watchAll=false
              set TEST_EXIT_CODE=%ERRORLEVEL%
              cd /D "%WORKSPACE%"
              move "%TEMP%\\jenkins-workspaces\\%JOB_NAME%-my-app" my-app
              exit /B %TEST_EXIT_CODE%
            '''
          }  
        }  
      }  
    }  
  
    stage('Build frontend') {  
      steps {  
        dir('my-app') {  
          script {  
            if (isUnix()) {  
              sh 'npm run build'  
            } else {  
              bat 'npm run build'  
            }  
          }  
        }  
      }  
    }  
  }  
  
  post {  
    always {  
      cleanWs()  
    }  
  }  
} 
